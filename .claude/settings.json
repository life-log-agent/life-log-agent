{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(python *)",
      "Bash(pip *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force *)"
    ]
  },
  "env": {
    "NAVER_CLOVA_API_KEY": "",
    "NAVER_CLOVA_API_SECRET": "",
    "DB_HOST": "",
    "DB_PORT": "",
    "DB_NAME": "",
    "DB_USER": "",
    "DB_PASSWORD": ""
  }
}
