# 이 파일은 커밋됩니다 - 실제 값 X, 키 이름만 작성
# 팀원은 이 파일을 복사해서 .env 로 만든 후 실제 값을 채워넣으세요
# cp .env.example .env

# Naver Clova X API
NAVER_CLOVA_API_KEY=
NAVER_CLOVA_API_SECRET=
NAVER_CLOVA_API_URL=https://clovastudio.stream.naver.com

# Cloud DB (예: PostgreSQL / MySQL / Firebase 등)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# 앱 설정
NODE_ENV=development
PORT=3000
